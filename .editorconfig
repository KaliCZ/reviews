root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[{*.yaml,*.yml}]
indent_size = 2

[{*.json,*.jsonc}]
indent_size = 2

[{*.ts,*.tsx,*.js,*.jsx,*.html,*.css,*.scss}]
indent_size = 2

# ── C# / Razor ──────────────────────────────────────────────────────────────

[*.{cs,razor}]

# ── Naming: private fields are camelCase WITHOUT underscore prefix ───────────

dotnet_naming_rule.instance_fields_should_be_camel_case.severity = warning
dotnet_naming_rule.instance_fields_should_be_camel_case.symbols = instance_fields
dotnet_naming_rule.instance_fields_should_be_camel_case.style = instance_field_style

dotnet_naming_symbols.instance_fields.applicable_kinds = field
dotnet_naming_symbols.instance_fields.applicable_accessibilities = private, protected, protected_internal, private_protected
dotnet_naming_symbols.instance_fields.required_modifiers =

dotnet_naming_style.instance_field_style.capitalization = camel_case
dotnet_naming_style.instance_field_style.required_prefix =
dotnet_naming_style.instance_field_style.required_suffix =
dotnet_naming_style.instance_field_style.word_separator =

# ── Dangerous patterns → error ──────────────────────────────────────────────

dotnet_diagnostic.CS8600.severity = error    # Converting null literal or possible null value to non-nullable type
dotnet_diagnostic.CS8601.severity = error    # Possible null reference assignment
dotnet_diagnostic.CS8602.severity = error    # Dereference of a possibly null reference
dotnet_diagnostic.CS8603.severity = error    # Possible null reference return
dotnet_diagnostic.CS8604.severity = error    # Possible null reference argument
dotnet_diagnostic.CS8618.severity = error    # Non-nullable property must contain a non-null value when exiting constructor
dotnet_diagnostic.CS8509.severity = error    # Incomplete switch expression (named values)
dotnet_diagnostic.CS4014.severity = error    # Call not awaited (fire-and-forget)
dotnet_diagnostic.CA2016.severity = error    # Forward CancellationToken to methods that accept it
dotnet_diagnostic.CA1851.severity = error    # Multiple enumeration of IEnumerable

# EF Core analyzer — model validation warnings (string without max length etc.)
dotnet_diagnostic.EF1001.severity = warning
dotnet_diagnostic.EF1002.severity = warning

# ReSharper equivalent for multiple enumeration
resharper_possible_multiple_enumeration_highlighting = error

# ── Code quality → error ────────────────────────────────────────────────────

dotnet_diagnostic.IDE0001.severity = error   # Simplify names
dotnet_diagnostic.IDE0005.severity = warning # Remove unnecessary using
dotnet_diagnostic.IDE0051.severity = warning # Remove unused private members
dotnet_diagnostic.IDE0161.severity = error   # Use file-scoped namespace

# ── Style preferences → suggestion ──────────────────────────────────────────

dotnet_diagnostic.IDE0290.severity = suggestion # Use primary constructor
dotnet_diagnostic.IDE0028.severity = suggestion # Simplify collection initialization
dotnet_diagnostic.IDE0300.severity = suggestion # Simplify collection initialization
dotnet_diagnostic.IDE0301.severity = suggestion # Simplify collection initialization
dotnet_diagnostic.IDE0055.severity = suggestion # Fix formatting
dotnet_diagnostic.CS8524.severity = suggestion  # Incomplete switch including unnamed enum values

# ── var usage ───────────────────────────────────────────────────────────────

csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# ── Member qualification (don't require this.) ──────────────────────────────

dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# ── Modifier preferences ───────────────────────────────────────────────────

dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion
csharp_preferred_modifier_order = public, private, protected, internal, file, new, static, abstract, virtual, sealed, readonly, override, extern, unsafe, volatile, async, required:suggestion

# ── Suppress noise ──────────────────────────────────────────────────────────

dotnet_diagnostic.CS1591.severity = none     # Missing XML comment for public type

# Migrations are generated; don't enforce style on them.
[**/Migrations/*.cs]
generated_code = true
dotnet_analyzer_diagnostic.severity = none
